# AWS Configuration
aws_region        = "us-east-1"
aws_instance_type = "t3.large"  # 2 vCPUs, 8GB RAM

# Elastic Cloud Configuration
ec_region                = "aws-us-east-1"  # Must match AWS region or be nearby
deployment_name          = "traefik-otel-demo"
elasticsearch_size       = "1g"
elasticsearch_zone_count = 1

# Networking
# allowed_ssh_cidr = "203.0.113.10/32"  # Optional: defaults to your current public IP
vpc_cidr         = "10.0.0.0/16"

# Project
project_name = "traefik-otel-demo"
